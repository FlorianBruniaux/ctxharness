#!/usr/bin/env bash
# ctxharness — post-merge hook
# Checks AI doc drift after git pull / merge.
# Install: cp templates/husky/post-merge .husky/post-merge && chmod +x .husky/post-merge

if command -v ctxharness &>/dev/null; then
  if [ -f ".ctxharness.yml" ]; then
    # Full enforcement mode — exits 1 on drift (blocking)
    ctxharness check || {
      echo ""
      echo "⚠  AI doc drift detected. Run: ctxharness fix --apply"
      echo ""
    }
  else
    # Zero-config discovery mode — always exits 0 (informational)
    ctxharness scan --exit-zero
  fi
fi
